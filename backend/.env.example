JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change-this-to-another-long-random-string
JWT_REFRESH_EXPIRES_IN=7d
JWT_RESET_SECRET=change-this-to-yet-another-long-random-string

# ─────────────────────────────────────────────
# Redis (for JWT blacklisting & caching)
# ─────────────────────────────────────────────
