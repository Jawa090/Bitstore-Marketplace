# ─────────────────────────────────────────────
# Server
# ─────────────────────────────────────────────
NODE_ENV=development
PORT=3000

# ─────────────────────────────────────────────
# PostgreSQL Database
# ─────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=your_password_here
DB_NAME=bitstores

# ─────────────────────────────────────────────
# JWT Authentication
# ─────────────────────────────────────────────
JWT_SECRET=change-this-to-a-long-random-string
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change-this-to-another-long-random-string
JWT_REFRESH_EXPIRES_IN=7d
JWT_RESET_SECRET=change-this-to-yet-another-long-random-string

# ─────────────────────────────────────────────
# Redis (for JWT blacklisting & caching)
# ─────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379

# ─────────────────────────────────────────────
# Google OAuth
# ─────────────────────────────────────────────
GOOGLE_CLIENT_ID=653227713797-nlr9t8hoqia8rcgui3s3rbo61r8cdi2o.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ─────────────────────────────────────────────
# Cloudinary (Profile Picture Upload)
# ─────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=dhckshuxy
CLOUDINARY_API_KEY=558491954733281
CLOUDINARY_API_SECRET=gFMYRsDDzmo8WVWJDnAO6b129wc

# ─────────────────────────────────────────────
# Email (SMTP)
# ─────────────────────────────────────────────
